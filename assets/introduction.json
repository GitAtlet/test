  "commentary": {
    "1": {
      "text": "November 1918: World War I ends. The Kaiser abdicates, the republic is proclaimed, and the peace terms leave Germany shaken and unstable.",
      "date": "1918–1919"
    },
    "2": {
      "text": "February 1920: In Munich, the party is renamed NSDAP. Hitler presents the 25-point program, and the movement stays small but grows louder.",
      "date": "1920–1921"
    },
    "3": {
      "text": "November 1923: Hyperinflation peaks at 4.2 trillion Mark per US Dollar. The Munich putsch fails, Hitler is jailed, and the trial gives him national attention.",
      "date": "1923–1924"
    },
    "4": {
      "text": "1924–1928: During the \"Golden Twenties,\" recovery returns and NSDAP vote shares stay low. Hitler reorganizes and waits for a larger crisis.",
      "date": "1924–1928"
    }
  },

